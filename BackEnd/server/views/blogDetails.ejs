<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title><%= blog.title %></title>

  <!-- Font -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Inter', sans-serif;
    }

    body {
      background: #f6f8fc;
      color: #111827;
    }

    .blog-wrapper {
      width: 80%;
      max-width: 900px;
      margin: 50px auto;
      background: #fff;
      border-radius: 22px;
      box-shadow: 0 15px 40px rgba(0,0,0,0.08);
      overflow: hidden;
    }

    /* Hero Image */
    .blog-hero {
      position: relative;
    }

    .blog-hero img {
      width: 100%;
      height: 360px;
      object-fit: cover;
    }

    .date-badge {
      position: absolute;
      top: 18px;
      left: 18px;
      background: #fff;
      padding: 6px 14px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
    }

    /* Content */
    .blog-content {
      padding: 40px;
    }

    .blog-title {
      font-size: 36px;
      font-weight: 700;
      line-height: 1.3;
      margin-bottom: 12px;
    }

    .blog-meta {
      font-size: 14px;
      color: #6b7280;
      margin-bottom: 25px;
    }

    .blog-body {
      font-size: 17px;
      line-height: 1.8;
      color: #374151;
      white-space: pre-line;
    }

    /* Back Link */
    .back-link {
      text-align: center;
      margin: 30px 0 60px;
    }

    .back-link a {
      color: #6366f1;
      font-weight: 600;
      text-decoration: none;
    }

    .back-link a:hover {
      text-decoration: underline;
    }

    /* Responsive */
    @media (max-width: 768px) {
      .blog-wrapper {
        width: 92%;
      }

      .blog-title {
        font-size: 28px;
      }

      .blog-content {
        padding: 25px;
      }

      .blog-hero img {
        height: 260px;
      }
    }
  </style>
</head>

<body>

  <div class="blog-wrapper">

    <% if (blog.image_url) { %>
      <div class="blog-hero">
        <img src="<%= blog.image_url %>" alt="<%= blog.title %>">
        <span class="date-badge">
          <%= new Date(blog.created_at).toDateString() %>
        </span>
      </div>
    <% } %>

    <div class="blog-content">
      <h1 class="blog-title"><%= blog.title %></h1>

      <div class="blog-meta">
        By <strong><%= blog.author || 'StudySync Team' %></strong>
      </div>

      <div class="blog-body">
        <%= blog.content %>
      </div>
    </div>

  </div>

  <div class="back-link">
    <a href="/blogs">← Back to Blogs</a>
  </div>

</body>
</html>
