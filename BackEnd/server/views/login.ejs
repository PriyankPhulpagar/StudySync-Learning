<%- include('partials/header') %>

<div class="content">
  <div class="main-section" style="flex-direction: column; gap: 2rem; padding: 2rem;">
    <div class="content-left" style="width: 100%; text-align: center;">
      <h1 class="section-title">Login to StudySync</h1>
      <p class="section-description">
        Access your account to continue your seamless learning journey.
      </p>

      <% if (error) { %>
        <div style="background-color: #f8d7da; color: #721c24; padding: 1rem; margin-bottom: 1rem; border-radius: 0.5rem; max-width: 400px; margin: 0 auto;">
          <%= error %>
        </div>
      <% } %>

      <div class="card" style="max-width: 500px; margin: 2rem auto; padding: 2rem; border-radius: 1rem; box-shadow: 0px 4px 12px rgba(0,0,0,0.1);">
        <form action="/login" method="POST" style="display: flex; flex-direction: column; gap: 1.5rem;">
          <input 
            type="email" 
            name="email" 
            placeholder="Enter your email" 
            class="email-input" 
            required
            value="<%= email %>" 
          >
          <input 
            type="password" 
            name="password" 
            placeholder="Enter your password" 
            class="email-input" 
            required
          >
          <button type="submit" class="start-button">Login</button>
        </form>
      </div>

      <p class="section-description">Or login with</p>
      <a href="/auth/google" class="tour-button" style="max-width: 200px; display: inline-block; margin-top: 1rem;">
        <i class="fab fa-google"></i> Google
      </a>

      <p class="section-description" style="margin-top: 1rem;">
        Don't have an account? <a href="/register" class="link" style="color: var(--primary-color); text-decoration: underline;">Register here</a>
      </p>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
