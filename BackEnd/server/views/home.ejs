<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StudySync</title>

    <!-- CSS Corrected Path -->
    <link rel="stylesheet" href="/css/style.css">

</head>
<body>

    <div class="header">
        <header class="header-content">
            <a href="/" class="logo">
                <img src="/Images/StudySyn.svg" alt="logoImage" class="logo-icon">
                <span class="logo-text">StudySync</span>
            </a>

            <nav class="nav">
                <a href="/" class="nav-link">Home</a>
               
               
                <a href="/blogs" class="nav-link">Blog</a>
                <a href="/about" class="nav-link">About</a>
            </nav>

            <a  class="contact-button">Contact Us</a>

            <button class="menu-button">
                <img src="/Images/Hamburger.svg" alt="menu" class="menu-icon">
            </button>
        </header>
    </div>


    <!-- MAIN HERO SECTION -->
    <div class="content">
        <div class="main-section">

            <div class="content-left">
                <p class="section-label">Very proud to introduce</p>
                <h1 class="section-title">Seamless Learning for Brighter Futures</h1>
                <p class="section-description">
                    Our innovative platform offers an effortless approach to learning, empowering 
                    students of all ages to achieve brighter futures. Join us to simplify education 
                    and unlock your full potential.
                </p>

                <div class="button-group">
                    <a href="/login" class="start-button">Start Now</a>
                   
                </div>
            </div>

            <div class="content-right">
                <div class="image-container">
                    <img src="/Images/usgs-hoS3dzgpHzw-unsplash.jpg" class="section-image">
                </div>
            </div>
        </div>
    </div>


    <!-- COMPANIES -->
    <div class="company-container">
        <h2 class="company-title">Trusted by the best</h2>

        <div class="company-grid">
            <div class="company-logo">
                <img src="/Images/Google.svg" class="svg-image"><span>Google</span>
            </div>
            <div class="company-logo">
                <img src="/Images/Microsoft.svg" class="svg-image"><span>Microsoft</span>
            </div>
            <div class="company-logo">
                <img src="/Images/linkedin.svg" class="svg-image"><span>LinkedIn</span>
            </div>
            <div class="company-logo">
                <img src="/Images/VectorEdu.svg" class="svg-image"><span>VectorEdu</span>
            </div>
        </div>
    </div>


    <!-- FEATURE SECTION -->
    <div class="feature-container">
        <div class="feature-content">
            <div class="main-info">
                <h1 class="feature-title">Our competitive advantage</h1>
                <p class="feature-description">
                    Placeholder text describing key platform strengths and benefits.
                </p>
            </div>

            <div class="feature-grid">
                <div class="feature-card"><img src="/Images/PersonalizedLearn.svg" class="feature-svg"><div class="feature-info"><div class="title">Personalized Learning</div><div class="description">Customized learning paths for each student.</div></div></div>
                <div class="feature-card"><img src="/Images/Affordability (2).svg" class="feature-svg"><div class="feature-info"><div class="title">Affordability</div><div class="description">Low-cost education for everyone.</div></div></div>
                <div class="feature-card"><img src="/Images/IndustryPatner.svg" class="feature-svg"><div class="feature-info"><div class="title">Industry Partnerships</div><div class="description">Real-world internships & learning exposure.</div></div></div>
                <div class="feature-card"><img src="/Images/InnovativeTech.svg" class="feature-svg"><div class="feature-info"><div class="title">Innovative Technology</div><div class="description">Modern tech boosting learning quality.</div></div></div>
                <div class="feature-card"><img src="/Images/IndustryPatner.svg" class="feature-svg"><div class="feature-info"><div class="title">Responsive Support</div><div class="description">24/7 help for students.</div></div></div>
                <div class="feature-card"><img src="/Images/Analytics.svg" class="feature-svg"><div class="feature-info"><div class="title">Analytics & Insights</div><div class="description">Smart guidance based on progress tracking.</div></div></div>
            </div>
        </div>
    </div>


    <!-- TESTIMONIALS -->
    <div class="testimonial-container">
        <div class="testimonial-content">
            <h2 class="testimonial-title">What Others Say About Us</h2>

            <div class="testimonial-grid">
                <div class="testimonial-card"><p class="testimonial-text">"Amazing learning experience!"</p><img src="/Images/avatar1.png" class="testimonial-image"><h3>Sarah Johnson</h3><p>Teacher</p></div>
                <div class="testimonial-card"><p class="testimonial-text">"StudySync changed how I study."</p><img src="/Images/avatar2.png" class="testimonial-image"><h3>Michael Lee</h3><p>Student</p></div>
                <div class="testimonial-card"><p class="testimonial-text">"Highly effective platform!"</p><img src="/Images/avatar3.png" class="testimonial-image"><h3>Priyank</h3><p>Developer</p></div>
            </div>
        </div>
    </div>


    <!-- NEWSLETTER -->
    <div class="newsletter-container">
        <div class="newsletter-section">
            <div class="news-left">
                <img src="/Images/img.png" class="newsletter-image">
            </div>

            <div class="content-info">
                <h1 class="newsletter-title">Get the latest updates</h1>
                <p class="newsletter-description">Sign up for our newsletter</p>

                <div class="email">
                    <input type="text" placeholder="Email" class="email-input">
                    <button class="send-button">Send</button>
                </div>

                <p class="content-foot">
                    By signing up you agree to our <a>Terms</a> & <a>Policy</a>
                </p>
            </div>
        </div>
    </div>


    <!-- FOOTER -->
    <div class="footer-container">
    <footer class="footer">

    
        <div class="footer-copyright">
            &copy; 2025 StudySync. All rights reserved.
        </div>
    </footer>
</div>

