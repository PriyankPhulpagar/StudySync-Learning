<%- include('partials/header') %>

<div class="container mt-5">
  <h1>Register</h1>

  <% if (email) { %>
    <div style="background-color: #d1ecf1; color: #0c5460; padding: 1rem; margin-bottom: 1rem; border-radius: 0.5rem;">
      This email is new, please register
    </div>
  <% } %>

  <div class="row">
    <!-- Register Form -->
    <div class="col-sm-8">
      <div class="card">
        <div class="card-body">
          <form action="/register" method="POST">
            <div class="form-group mb-3">
              <label for="name">Name</label>
              <input type="text" class="form-control" name="name" placeholder="Enter your name" required>
            </div>
            <div class="form-group mb-3">
              <label for="email">Email</label>
              <input type="email" name="email" placeholder="Enter your email" class="form-control" required
                value="<%= email || '' %>" 
              >
            </div>
            <div class="form-group mb-3">
              <label for="password">Password</label>
              <input type="password" class="form-control" name="password" placeholder="Enter your password" required>
            </div>
            <button type="submit" class="btn btn-dark w-100">Register</button>
          </form>
        </div>
      </div>
    </div>

    <!-- Google Signup -->
    <div class="col-sm-4">
      <div class="card social-block">
        <div class="card-body text-center">
          <a class="btn btn-danger w-100" href="/auth/google" role="button">
            <i class="fab fa-google"></i> Sign Up with Google
          </a>
        </div>
      </div>
    </div>
  </div>

  <p class="text-center mt-3">
    Already have an account? <a href="/login" class="text-decoration-underline">Login here</a>
  </p>
</div>

<%- include('partials/footer') %>
